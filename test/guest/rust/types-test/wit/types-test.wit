package test:types;

interface host-fns {
  record point {
    x: f64,
    y: f64,
  }

  echo-string: func(s: string) -> string;
  add-integers: func(a: s32, b: s32) -> s32;
  scale-point: func(p: point, factor: f64) -> point;
  sum-list: func(nums: list<s32>) -> s32;
  async-double: async func(n: u32) -> u32;
  log: func(msg: string);
}

interface api {
  record point {
    x: f64,
    y: f64,
  }

  record person {
    name: string,
    age: u32,
  }

  enum color {
    red,
    green,
    blue,
  }

  greet: func(name: string) -> string;
  compute-distance: func(a: point, b: point) -> f64;
  color-to-number: func(c: color) -> u32;
  describe-person: func(p: person) -> string;
  reverse-list: func(nums: list<s32>) -> list<s32>;
  safe-divide: func(a: f64, b: f64) -> result<f64, string>;
  double-sum: async func(a: u32, b: u32) -> u32;
}

world types-test {
  import host-fns;
  export api;
}
